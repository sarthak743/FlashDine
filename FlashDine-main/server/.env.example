# -------------------------------------------------------------------
# FlashDine Backend — Environment Variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------------------

# Port the Express server listens on
PORT=3001

# Comma-separated frontend origins allowed to call the API directly.
# Localhost and 127.0.0.1 on Vite ports are allowed by default even if unset.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Secret used to sign session cookies (generate a long random string)
SESSION_SECRET=change_me_to_a_long_random_secret

# Admin credentials — password is stored as a bcrypt hash.
# To generate a hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
# Default plain-text password for demo: admin123
ADMIN_PASSWORD_HASH=$2b$12$tLGQTao2RVkDuRhjc1Ba/uPUmYHU5wP3/0h7qI4JSC2VgL2qbpGme

# Razorpay credentials (get from https://dashboard.razorpay.com)
# Use test keys (rzp_test_*) during development.
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# Razorpay webhook secret (set in Razorpay dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# Merchant UPI VPA shown in the QR / deeplink fallback
MERCHANT_UPI=flashdine@upi
MERCHANT_NAME=FlashDine
